# ============================================
# MADAR - Smart Energy Management Platform
# Environment Variables Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ─────────────────────────────
# Supabase Configuration
# ─────────────────────────────
# Get these from: https://supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─────────────────────────────
# Express Backend
# ─────────────────────────────
EXPRESS_PORT=3001

# ─────────────────────────────
# Python Control Service
# ─────────────────────────────
FLASK_PORT=5000

# ─────────────────────────────
# Serial (Arduino UNO)
# ─────────────────────────────
SERIAL_PORT=COM3
BAUD_RATE=9600

# ─────────────────────────────
# ESP32-CAM
# ─────────────────────────────
# IP address of ESP32-CAM on your local network
ESP32_CAM_IP=192.168.1.57

# ─────────────────────────────
# Vite Frontend (optional)
# ─────────────────────────────
# Override Express URL for production deployment
# VITE_EXPRESS_URL=http://your-server-ip:3001
